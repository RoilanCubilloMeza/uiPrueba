<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:UiPrueba1.Controls"
             x:Class="UiPrueba1.MainPage"
             x:Name="ThisPage"
             BackgroundColor="{DynamicResource PageBackground}"
             Shell.NavBarIsVisible="False">

    <Grid x:Name="MainGrid" ColumnDefinitions="560, *, 220" ColumnSpacing="0">


        <Border Grid.Column="0"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 12"
                Stroke="{DynamicResource Gray200Brush}"
                StrokeThickness="1"
                Margin="12,10,6,10"
                Padding="0">

            <Grid RowDefinitions="Auto, Auto, *, Auto" RowSpacing="0">

                <!-- Row 0: Client Info Header -->
                <Grid Grid.Row="0"
                      ColumnDefinitions="Auto, *, Auto, Auto"
                      ColumnSpacing="8"
                      Padding="14,12,14,10">
                    <Border Grid.Column="0"
                            BackgroundColor="{DynamicResource Gray200}"
                            StrokeShape="Ellipse" StrokeThickness="0"
                            WidthRequest="40" HeightRequest="40">
                        <Label Text="&#x1F464;" FontSize="18"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                        <Label Text="Cod. Cliente 3-101-718276"
                               FontSize="13" FontAttributes="Bold"
                               TextColor="{DynamicResource Gray900}"
                               LineBreakMode="TailTruncation"/>
                        <Label Text="AVS Solutions"
                               FontSize="11" TextColor="{DynamicResource Gray500}"/>
                    </VerticalStackLayout>
                    <Border Grid.Column="2"
                            BackgroundColor="{DynamicResource AccentBlue}"
                            StrokeShape="RoundRectangle 6" StrokeThickness="0"
                            Padding="10,6" HeightRequest="32">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnClientSearchTapped"/>
                        </Border.GestureRecognizers>
                        <Label Text="F2 Cliente" TextColor="White" FontAttributes="Bold"
                               FontSize="12" VerticalOptions="Center"/>
                    </Border>
                    <Border Grid.Column="3"
                            BackgroundColor="{DynamicResource InputBackground}"
                            StrokeShape="RoundRectangle 6" StrokeThickness="1"
                            Stroke="{DynamicResource Gray200Brush}"
                            Padding="10,6" HeightRequest="32">
                        <Label Text="F3" TextColor="{DynamicResource Gray600}"
                               FontAttributes="Bold" FontSize="12" VerticalOptions="Center"/>
                    </Border>
                </Grid>

                <!-- Row 1: Table Header -->
                <Border Grid.Row="1"
                        BackgroundColor="{DynamicResource InputBackground}"
                        StrokeShape="RoundRectangle 0" StrokeThickness="0"
                        Padding="12,8">
                    <Grid ColumnDefinitions="*, 30, 80, 86, 96" ColumnSpacing="6">
                        <Label Grid.Column="0" Text="Descripción Producto"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="{DynamicResource Gray500}"/>
                        <Label Grid.Column="1" Text="Cant."
                               FontSize="11" FontAttributes="Bold"
                               TextColor="{DynamicResource Gray500}"
                               HorizontalTextAlignment="Center"/>
                        <Label Grid.Column="2" Text="Precio"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="{DynamicResource Gray500}"
                               HorizontalTextAlignment="End"/>
                        <Label Grid.Column="3" Text="Total"
                               FontSize="11" FontAttributes="Bold"
                               TextColor="{DynamicResource Gray500}"
                               HorizontalTextAlignment="End"/>
                        <!-- Col 4: no header — reserved for −/+ controls -->
                    </Grid>
                </Border>

                <!-- Row 2: Cart Items (scroll) -->
                <CollectionView Grid.Row="2" ItemsSource="{Binding CartItems}" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <VerticalStackLayout Spacing="0">
                                <Grid ColumnDefinitions="*, 30, 80, 86, 96"
                                      ColumnSpacing="6" Padding="12,9,12,9">

                                    <!-- Col 0: prefix + emoji + name -->
                                    <Label Grid.Column="0"
                                           FontSize="13" FontAttributes="Bold"
                                           TextColor="{DynamicResource Gray900}"
                                           LineBreakMode="WordWrap"
                                           VerticalOptions="Start">
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="{Binding QuantityPrefix}"
                                                      TextColor="{DynamicResource AccentBlue}"
                                                      FontAttributes="Bold"/>
                                                <Span Text="  "/>
                                                <Span Text="{Binding Emoji}"/>
                                                <Span Text=" "/>
                                                <Span Text="{Binding Name}"/>
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>

                                    <!-- Col 1: quantity -->
                                    <Label Grid.Column="1"
                                           Text="{Binding QuantityPrefix}"
                                           FontSize="12"
                                           TextColor="{DynamicResource Gray600}"
                                           HorizontalTextAlignment="Center"
                                           VerticalOptions="Center"/>

                                    <!-- Col 2: unit price (colones + usd) -->
                                    <VerticalStackLayout Grid.Column="2"
                                                         VerticalOptions="Center"
                                                         HorizontalOptions="End"
                                                         Spacing="1">
                                        <Label Text="{Binding UnitPriceColonesText}"
                                               FontSize="13" FontAttributes="Bold"
                                               TextColor="{DynamicResource Gray900}"
                                               HorizontalTextAlignment="End"/>
                                        <Label Text="{Binding UnitPriceUsdText}"
                                               FontSize="11"
                                               TextColor="{DynamicResource Gray400}"
                                               HorizontalTextAlignment="End"/>
                                    </VerticalStackLayout>

                                    <!-- Col 3: total (colones + usd) -->
                                    <VerticalStackLayout Grid.Column="3"
                                                         VerticalOptions="Center"
                                                         HorizontalOptions="End"
                                                         Spacing="1">
                                        <Label Text="{Binding TotalColonesText}"
                                               FontSize="13" FontAttributes="Bold"
                                               TextColor="{DynamicResource Gray900}"
                                               HorizontalTextAlignment="End"/>
                                        <Label Text="{Binding TotalUsdText}"
                                               FontSize="11"
                                               TextColor="{DynamicResource Gray400}"
                                               HorizontalTextAlignment="End"/>
                                    </VerticalStackLayout>

                                    <!-- Col 4: − / qty / + touch controls -->
                                    <Grid Grid.Column="4"
                                          ColumnDefinitions="28, *, 28" ColumnSpacing="2"
                                          VerticalOptions="Center">
                                        <Border Grid.Column="0"
                                                BackgroundColor="{DynamicResource AccentOrange}"
                                                StrokeShape="RoundRectangle 7" StrokeThickness="0"
                                                HeightRequest="34" Padding="0">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.DecrementCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Label Text="−" FontSize="18" FontAttributes="Bold"
                                                   TextColor="White"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Border>
                                        <Label Grid.Column="1"
                                               Text="{Binding Quantity}"
                                               FontSize="13" FontAttributes="Bold"
                                               TextColor="{DynamicResource Gray900}"
                                               HorizontalTextAlignment="Center"
                                               VerticalOptions="Center"/>
                                        <Border Grid.Column="2"
                                                BackgroundColor="{DynamicResource AccentGreen}"
                                                StrokeShape="RoundRectangle 7" StrokeThickness="0"
                                                HeightRequest="34" Padding="0">
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer
                                                    Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.IncrementCommand}"
                                                    CommandParameter="{Binding .}"/>
                                            </Border.GestureRecognizers>
                                            <Label Text="+" FontSize="18" FontAttributes="Bold"
                                                   TextColor="White"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Border>
                                    </Grid>

                                </Grid>
                                <BoxView Color="{DynamicResource Gray100}" HeightRequest="1" Margin="12,0"/>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                    <CollectionView.EmptyView>
                        <Label Text="Carrito vacío" FontSize="13"
                               TextColor="{DynamicResource Gray400}"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               Margin="0,40,0,0"/>
                    </CollectionView.EmptyView>
                </CollectionView>

                <!-- Row 3: Totals + Actions -->
                <VerticalStackLayout Grid.Row="3" Spacing="0">

                    <BoxView Color="{DynamicResource Gray200}" HeightRequest="1"/>

                    <!-- Totals: Subtotal + TOTAL in colones -->
                    <Grid ColumnDefinitions="Auto, Auto, *, Auto, Auto"
                          Padding="14,12,14,4" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="Totales:"
                               FontSize="15" FontAttributes="Bold"
                               TextColor="{DynamicResource Gray600}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Subtotal:"
                               FontSize="13"
                               TextColor="{DynamicResource Gray500}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="2" Text="{Binding SubtotalColonesText}"
                               FontSize="17" FontAttributes="Bold"
                               TextColor="{DynamicResource Gray900}"/>
                        <Label Grid.Column="3" Text="TOTAL:"
                               FontSize="15" FontAttributes="Bold"
                               TextColor="{DynamicResource Gray600}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="4" Text="{Binding TotalColonesText}"
                               FontSize="17" FontAttributes="Bold"
                               TextColor="{DynamicResource Gray900}"
                               HorizontalTextAlignment="End"/>
                    </Grid>

                    <!-- USD totals: Impuestos + Total USD -->
                    <Grid ColumnDefinitions="Auto, Auto, *, Auto"
                          Padding="14,0,14,10" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="Impuestos:"
                               FontSize="13" TextColor="{DynamicResource Gray400}"/>
                        <Label Grid.Column="1" Text="{Binding TaxText}"
                               FontSize="13" TextColor="{DynamicResource Gray400}"/>
                        <BoxView Grid.Column="2" Color="Transparent" HeightRequest="0"/>
                        <Label Grid.Column="3" Text="{Binding TotalText}"
                               FontSize="13" TextColor="{DynamicResource Gray400}"
                               HorizontalTextAlignment="End"/>
                    </Grid>

                    <!-- Orange bar: Vaciar Ticket + Big TOTAL -->
                    <Border BackgroundColor="{DynamicResource AccentOrange}"
                            StrokeShape="RoundRectangle 0,0,12,12" StrokeThickness="0"
                            Padding="14,10">
                        <Grid ColumnDefinitions="Auto, *">
                            <Border Grid.Column="0"
                                    BackgroundColor="#C04800"
                                    StrokeShape="RoundRectangle 6" StrokeThickness="0"
                                    Padding="10,6" HeightRequest="38"
                                    VerticalOptions="Center">
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding ClearCartCommand}"/>
                                </Border.GestureRecognizers>
                                <HorizontalStackLayout Spacing="5">
                                    <Label Text="&#x1F5D1;" FontSize="13"
                                           TextColor="White" VerticalOptions="Center"/>
                                    <Label Text="Vaciar Ticket" TextColor="White"
                                           FontSize="12" FontAttributes="Bold"
                                           VerticalOptions="Center"/>
                                </HorizontalStackLayout>
                            </Border>
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                <!-- TC · Sub · IVA pills -->
                                <HorizontalStackLayout HorizontalOptions="End" Spacing="4">
                                    <Border BackgroundColor="#26000000"
                                            StrokeShape="RoundRectangle 6" StrokeThickness="0"
                                            Padding="8,4">
                                        <HorizontalStackLayout Spacing="5">
                                            <Label Text="TC" FontSize="10" TextColor="White"
                                                   Opacity="0.8" VerticalOptions="Center"/>
                                            <Label Text="{Binding ExchangeRateText}"
                                                   FontSize="12" FontAttributes="Bold"
                                                   TextColor="White" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                    </Border>
                                    <Border BackgroundColor="#26000000"
                                            StrokeShape="RoundRectangle 6" StrokeThickness="0"
                                            Padding="8,4">
                                        <HorizontalStackLayout Spacing="5">
                                            <Label Text="Sub" FontSize="10" TextColor="White"
                                                   Opacity="0.8" VerticalOptions="Center"/>
                                            <Label Text="{Binding SubtotalColonesText}"
                                                   FontSize="12" FontAttributes="Bold"
                                                   TextColor="White" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                    </Border>
                                    <Border BackgroundColor="#26000000"
                                            StrokeShape="RoundRectangle 6" StrokeThickness="0"
                                            Padding="8,4">
                                        <HorizontalStackLayout Spacing="5">
                                            <Label Text="IVA" FontSize="10" TextColor="White"
                                                   Opacity="0.8" VerticalOptions="Center"/>
                                            <Label Text="{Binding TaxColonesText}"
                                                   FontSize="12" FontAttributes="Bold"
                                                   TextColor="White" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                    </Border>
                                </HorizontalStackLayout>
                                <!-- Big total -->
                                <Label Text="TOTAL:" FontSize="12" TextColor="White"
                                       HorizontalTextAlignment="End" Opacity="0.85"/>
                                <Label Text="{Binding TotalColonesText}"
                                       FontSize="28" FontAttributes="Bold"
                                       TextColor="White"
                                       HorizontalTextAlignment="End"/>
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                </VerticalStackLayout>

            </Grid>
        </Border>

        <!-- Collapsed state: slim expand bar -->
        <Border Grid.Column="1"
                BackgroundColor="#1E293B"
                StrokeShape="RoundRectangle 12"
                StrokeThickness="0"
                Margin="6,10,6,10"
                IsVisible="False">
            <Border.Triggers>
                <DataTrigger TargetType="Border" Binding="{Binding IsProductsPanelVisible}" Value="False">
                    <Setter Property="IsVisible" Value="True"/>
                </DataTrigger>
            </Border.Triggers>
            <Border.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding ToggleProductsPanelCommand}"/>
            </Border.GestureRecognizers>
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                <Label Text="&#x1F4E6;" FontSize="18" TextColor="White"
                       HorizontalTextAlignment="Center"/>
                <Label Text="&#x25B6;" FontSize="16" TextColor="White"
                       HorizontalTextAlignment="Center" Opacity="0.7"/>
            </VerticalStackLayout>
        </Border>

        <!-- Expanded state: full products panel -->
        <Border Grid.Column="1"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 12"
                Stroke="{DynamicResource Gray200Brush}"
                StrokeThickness="1"
                Margin="6,10,6,10"
                IsVisible="{Binding IsProductsPanelVisible}">

            <Grid RowDefinitions="Auto, *" RowSpacing="0">

                <!-- Panel header -->
                <Border Grid.Row="0"
                        BackgroundColor="#1E293B"
                        StrokeShape="RoundRectangle 11,11,0,0"
                        StrokeThickness="0"
                        Padding="12,8">
                    <Grid ColumnDefinitions="Auto, Auto, *, Auto"
                          ColumnSpacing="6">
                        <Label Grid.Column="0" Text="&#x1F4E6;"
                               FontSize="14" TextColor="White"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Productos"
                               TextColor="White" FontSize="13"
                               FontAttributes="Bold"
                               VerticalOptions="Center"/>

                        <!-- Column picker: 2 | 3 | 4 -->
                        <HorizontalStackLayout Grid.Column="2"
                                               HorizontalOptions="End" Spacing="3"
                                               VerticalOptions="Center">
                            <Border Padding="8,4" HeightRequest="24" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 5" BackgroundColor="Transparent">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSpan2}" Value="True">
                                        <Setter Property="BackgroundColor" Value="#475569"/>
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectSpanCommand}" CommandParameter="2"/>
                                </Border.GestureRecognizers>
                                <Label Text="2" FontSize="11" FontAttributes="Bold"
                                       TextColor="White" VerticalOptions="Center"/>
                            </Border>
                            <Border Padding="8,4" HeightRequest="24" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 5" BackgroundColor="Transparent">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSpan3}" Value="True">
                                        <Setter Property="BackgroundColor" Value="#475569"/>
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectSpanCommand}" CommandParameter="3"/>
                                </Border.GestureRecognizers>
                                <Label Text="3" FontSize="11" FontAttributes="Bold"
                                       TextColor="White" VerticalOptions="Center"/>
                            </Border>
                            <Border Padding="8,4" HeightRequest="24" StrokeThickness="0"
                                    StrokeShape="RoundRectangle 5" BackgroundColor="Transparent"
                                    IsVisible="{Binding IsSpan4Available}">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSpan4}" Value="True">
                                        <Setter Property="BackgroundColor" Value="#475569"/>
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding SelectSpanCommand}" CommandParameter="4"/>
                                </Border.GestureRecognizers>
                                <Label Text="4" FontSize="11" FontAttributes="Bold"
                                       TextColor="White" VerticalOptions="Center"/>
                            </Border>
                        </HorizontalStackLayout>

                        <!-- Collapse button -->
                        <Border Grid.Column="3"
                                BackgroundColor="#475569"
                                StrokeShape="RoundRectangle 5"
                                StrokeThickness="0"
                                WidthRequest="28" HeightRequest="28"
                                Padding="0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleProductsPanelCommand}"/>
                            </Border.GestureRecognizers>
                            <Label Text="&#x25C0;" FontSize="11" TextColor="White"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Panel content -->
                <Grid x:Name="ProductsPanel" Grid.Row="1" RowDefinitions="Auto, Auto, *, Auto"
                      RowSpacing="0" Padding="10,8,10,10"
                      SizeChanged="OnProductsPanelSizeChanged">

                    <!-- Row 0: Search bar -->
                    <Border Grid.Row="0" Style="{DynamicResource InputBox}" Margin="0,2,0,8">
                        <Grid ColumnDefinitions="Auto, *">
                            <Label Grid.Column="0" Text="&#x1F50D;&#xFE0E;" FontSize="15"
                           TextColor="{DynamicResource Gray400}"
                           VerticalOptions="Center" Margin="0,0,6,0"/>
                    <Entry Grid.Column="1"
                           Placeholder="Buscar o escanear producto..."
                           Text="{Binding ProductSearchText, Mode=TwoWay}"
                           FontSize="13" BackgroundColor="Transparent"/>
                </Grid>
            </Border>

            <!-- Row 1: Category tabs -->
            <ScrollView Grid.Row="1" Orientation="Horizontal"
                        HorizontalScrollBarVisibility="Never"
                        Margin="0,0,0,8">
                <HorizontalStackLayout Spacing="6">
                    <!-- Todos -->
                    <Border StrokeShape="RoundRectangle 20" Padding="14,8"
                            StrokeThickness="0" BackgroundColor="White">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectCategoryCommand}"
                                                  CommandParameter="Todos"/>
                        </Border.GestureRecognizers>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsCatTodos}" Value="True">
                                <Setter Property="BackgroundColor" Value="{DynamicResource AccentBlue}"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Border" Binding="{Binding IsCatTodos}" Value="False">
                                <Setter Property="BackgroundColor" Value="White"/>
                                <Setter Property="StrokeThickness" Value="1"/>
                                <Setter Property="Stroke" Value="{DynamicResource Gray200Brush}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Label Text="&#x1F3F7;&#xFE0F; Todos" FontSize="12"
                               TextColor="{DynamicResource Gray600}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsCatTodos}" Value="True">
                                    <Setter Property="TextColor" Value="White"/>
                                    <Setter Property="FontAttributes" Value="Bold"/>
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Border>
                    <!-- Super -->
                    <Border StrokeShape="RoundRectangle 20" Padding="14,8"
                            StrokeThickness="0" BackgroundColor="White">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectCategoryCommand}"
                                                  CommandParameter="Super"/>
                        </Border.GestureRecognizers>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsCatSuper}" Value="True">
                                <Setter Property="BackgroundColor" Value="{DynamicResource AccentBlue}"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Border" Binding="{Binding IsCatSuper}" Value="False">
                                <Setter Property="BackgroundColor" Value="White"/>
                                <Setter Property="StrokeThickness" Value="1"/>
                                <Setter Property="Stroke" Value="{DynamicResource Gray200Brush}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Label Text="&#x1F6D2; Super" FontSize="12"
                               TextColor="{DynamicResource Gray600}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsCatSuper}" Value="True">
                                    <Setter Property="TextColor" Value="White"/>
                                    <Setter Property="FontAttributes" Value="Bold"/>
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Border>
                    <!-- Ferreteria -->
                    <Border StrokeShape="RoundRectangle 20" Padding="14,8"
                            StrokeThickness="0" BackgroundColor="White">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectCategoryCommand}"
                                                  CommandParameter="Ferreteria"/>
                        </Border.GestureRecognizers>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsCatFerreteria}" Value="True">
                                <Setter Property="BackgroundColor" Value="{DynamicResource AccentBlue}"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Border" Binding="{Binding IsCatFerreteria}" Value="False">
                                <Setter Property="BackgroundColor" Value="White"/>
                                <Setter Property="StrokeThickness" Value="1"/>
                                <Setter Property="Stroke" Value="{DynamicResource Gray200Brush}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Label Text="&#x1F527; Ferretería" FontSize="12"
                               TextColor="{DynamicResource Gray600}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsCatFerreteria}" Value="True">
                                    <Setter Property="TextColor" Value="White"/>
                                    <Setter Property="FontAttributes" Value="Bold"/>
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Border>
                    <!-- Calzado -->
                    <Border StrokeShape="RoundRectangle 20" Padding="14,8"
                            StrokeThickness="0" BackgroundColor="White">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectCategoryCommand}"
                                                  CommandParameter="Calzado"/>
                        </Border.GestureRecognizers>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsCatCalzado}" Value="True">
                                <Setter Property="BackgroundColor" Value="{DynamicResource AccentBlue}"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Border" Binding="{Binding IsCatCalzado}" Value="False">
                                <Setter Property="BackgroundColor" Value="White"/>
                                <Setter Property="StrokeThickness" Value="1"/>
                                <Setter Property="Stroke" Value="{DynamicResource Gray200Brush}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Label Text="&#x1F45F; Calzado" FontSize="12"
                               TextColor="{DynamicResource Gray600}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsCatCalzado}" Value="True">
                                    <Setter Property="TextColor" Value="White"/>
                                    <Setter Property="FontAttributes" Value="Bold"/>
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Border>
                    <!-- Hogar -->
                    <Border StrokeShape="RoundRectangle 20" Padding="14,8"
                            StrokeThickness="0" BackgroundColor="White">
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding SelectCategoryCommand}"
                                                  CommandParameter="Hogar"/>
                        </Border.GestureRecognizers>
                        <Border.Triggers>
                            <DataTrigger TargetType="Border" Binding="{Binding IsCatHogar}" Value="True">
                                <Setter Property="BackgroundColor" Value="{DynamicResource AccentBlue}"/>
                            </DataTrigger>
                            <DataTrigger TargetType="Border" Binding="{Binding IsCatHogar}" Value="False">
                                <Setter Property="BackgroundColor" Value="White"/>
                                <Setter Property="StrokeThickness" Value="1"/>
                                <Setter Property="Stroke" Value="{DynamicResource Gray200Brush}"/>
                            </DataTrigger>
                        </Border.Triggers>
                        <Label Text="&#x1F3E0; Hogar" FontSize="12"
                               TextColor="{DynamicResource Gray600}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsCatHogar}" Value="True">
                                    <Setter Property="TextColor" Value="White"/>
                                    <Setter Property="FontAttributes" Value="Bold"/>
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </Border>
                </HorizontalStackLayout>
            </ScrollView>

            <!-- Row 2: Product Grid (2-4 columns, responsive) -->
            <CollectionView Grid.Row="2" ItemsSource="{Binding Products}" SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <GridItemsLayout x:Name="ProductsItemsLayout" Orientation="Vertical" Span="2"
                                     HorizontalItemSpacing="10" VerticalItemSpacing="10"/>
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <controls:ProductCard Emoji="{Binding Emoji}"
                                              ProductName="{Binding Name}"
                                              Code="{Binding Code}"
                                              Price="{Binding Price}"
                                              PriceColones="{Binding PriceColonesText}"
                                              OldPrice="{Binding OldPrice}"
                                              Stock="{Binding Stock}"
                                              Quantity="{Binding CartQuantity}"
                                              Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.AddProductCommand}"
                                              CommandParameter="{Binding .}"
                                              DecrementCommand="{Binding Source={x:Reference ThisPage}, Path=BindingContext.DecrementProductCommand}"
                                              DecrementCommandParameter="{Binding .}"/>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Row 3: Exchange Rate + Cobrar -->
            <VerticalStackLayout Grid.Row="3" Spacing="8" Margin="0,8,0,0">

                <!-- Tipo de Cambio -->
                <Border BackgroundColor="White"
                        StrokeShape="RoundRectangle 8" StrokeThickness="1"
                        Stroke="{DynamicResource Gray200Brush}"
                        Padding="12,8">
                    <Grid ColumnDefinitions="Auto, Auto, Auto, *, Auto" ColumnSpacing="8">
                        <Label Grid.Column="0" Text="&#x1F1FA;&#x1F1F8;" FontSize="16"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="1" Text="Tipo de Cambio" FontSize="12"
                               FontAttributes="Bold" TextColor="{DynamicResource Gray600}"
                               VerticalOptions="Center"/>
                        <Label Grid.Column="2" Text="USD &#x2192; CRC" FontSize="12"
                               TextColor="{DynamicResource Gray400}"
                               VerticalOptions="Center"/>
                        <Border Grid.Column="3"
                                BackgroundColor="{DynamicResource InputBackground}"
                                StrokeShape="RoundRectangle 6" StrokeThickness="1"
                                Stroke="{DynamicResource Gray200Brush}"
                                Padding="10,4" HorizontalOptions="Start">
                            <Label Text="{Binding ExchangeRateText}" FontSize="13"
                                   FontAttributes="Bold"
                                   TextColor="{DynamicResource Gray900}"/>
                        </Border>
                        <Label Grid.Column="4" Text="&#x1F504;" FontSize="14"
                               TextColor="{DynamicResource Gray400}"
                               VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Cobrar Button -->
                <Border BackgroundColor="{DynamicResource AccentGreen}"
                        StrokeShape="RoundRectangle 10" StrokeThickness="0"
                        HeightRequest="50" Padding="10,0">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding InvoiceCommand}"/>
                    </Border.GestureRecognizers>
                    <HorizontalStackLayout HorizontalOptions="Center"
                                           VerticalOptions="Center" Spacing="8">
                        <Label Text="&#x2611;" FontSize="18" TextColor="White"
                               VerticalOptions="Center"/>
                        <Label Text="Cobrar" FontSize="17" FontAttributes="Bold"
                               TextColor="White" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                </Border>

            </VerticalStackLayout>
                </Grid>
            </Grid>
        </Border>

        <!-- RIGHT PANEL: EXCHANGE RATE + ACTIONS        -->
        <Border Grid.Column="2"
                BackgroundColor="White"
                StrokeShape="RoundRectangle 12"
                Stroke="{DynamicResource Gray200Brush}"
                StrokeThickness="1"
                Margin="6,10,12,10"
                Padding="0">

            <ScrollView>
                <VerticalStackLayout Spacing="0" Padding="14,14">

                    <!-- Tipo de Cambio -->
                    <Label Text="Tipo de Cambio" FontSize="12" FontAttributes="Bold"
                           TextColor="{DynamicResource Gray600}" Margin="0,0,0,6"/>

                    <Border BackgroundColor="{DynamicResource InputBackground}"
                            StrokeShape="RoundRectangle 8" StrokeThickness="1"
                            Stroke="{DynamicResource Gray200Brush}"
                            Padding="10,8" Margin="0,0,0,14">
                        <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="6">
                            <Label Grid.Column="0" Text="USD &#x2192; CRC" FontSize="12"
                                   TextColor="{DynamicResource Gray500}"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="1" Text="{Binding ExchangeRateText}"
                                   FontSize="14" FontAttributes="Bold"
                                   TextColor="{DynamicResource Gray900}"
                                   HorizontalTextAlignment="End"
                                   VerticalOptions="Center"/>
                            <Label Grid.Column="2" Text="&#x1F504;" FontSize="12"
                                   TextColor="{DynamicResource Gray400}"
                                   VerticalOptions="Center"/>
                        </Grid>
                    </Border>

                    <BoxView Style="{DynamicResource FormDivider}" Margin="0,0,0,14"/>

                    <!-- Action Buttons -->
                    <VerticalStackLayout Spacing="6">

                        <!-- Cotización → Azul -->
                        <Border Style="{DynamicResource PaymentLinkRow}"
                                BackgroundColor="#EFF6FF" Stroke="#BFDBFE">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
                                <Border Grid.Column="0" Style="{DynamicResource PaymentIconBadge}"
                                        BackgroundColor="#3B82F6">
                                    <Label Text="&#x1F4CB;" FontSize="16"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Grid.Column="1" Text="Cotización"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#1D4ED8" VerticalOptions="Center"/>
                                <Label Grid.Column="2" Text="&#x276F;" FontSize="14"
                                       TextColor="#3B82F6" Opacity="0.6" VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- Rec. Cotización → Verde esmeralda -->
                        <Border Style="{DynamicResource PaymentLinkRow}"
                                BackgroundColor="#F0FDF4" Stroke="#BBF7D0">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
                                <Border Grid.Column="0" Style="{DynamicResource PaymentIconBadge}"
                                        BackgroundColor="#10B981">
                                    <Label Text="&#x1F4E5;" FontSize="16"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Grid.Column="1" Text="Rec. Cotización"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#065F46" VerticalOptions="Center"/>
                                <Label Grid.Column="2" Text="&#x276F;" FontSize="14"
                                       TextColor="#10B981" Opacity="0.6" VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- Fac. Espera → Ámbar -->
                        <Border Style="{DynamicResource PaymentLinkRow}"
                                BackgroundColor="#FFFBEB" Stroke="#FDE68A">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
                                <Border Grid.Column="0" Style="{DynamicResource PaymentIconBadge}"
                                        BackgroundColor="#F59E0B">
                                    <Label Text="&#x23F8;&#xFE0E;" FontSize="14"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Grid.Column="1" Text="Fac. Espera"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#92400E" VerticalOptions="Center"/>
                                <Label Grid.Column="2" Text="&#x276F;" FontSize="14"
                                       TextColor="#F59E0B" Opacity="0.6" VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- Rec. Espera → Violeta -->
                        <Border Style="{DynamicResource PaymentLinkRow}"
                                BackgroundColor="#F5F3FF" Stroke="#DDD6FE">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
                                <Border Grid.Column="0" Style="{DynamicResource PaymentIconBadge}"
                                        BackgroundColor="#8B5CF6">
                                    <Label Text="&#x1F504;" FontSize="16"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Grid.Column="1" Text="Rec. Espera"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#5B21B6" VerticalOptions="Center"/>
                                <Label Grid.Column="2" Text="&#x276F;" FontSize="14"
                                       TextColor="#8B5CF6" Opacity="0.6" VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- Orden Pedido → Índigo -->
                        <Border Style="{DynamicResource PaymentLinkRow}"
                                BackgroundColor="#EEF2FF" Stroke="#C7D2FE">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
                                <Border Grid.Column="0" Style="{DynamicResource PaymentIconBadge}"
                                        BackgroundColor="#6366F1">
                                    <Label Text="&#x1F4E6;" FontSize="16"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Grid.Column="1" Text="Orden Pedido"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#3730A3" VerticalOptions="Center"/>
                                <Label Grid.Column="2" Text="&#x276F;" FontSize="14"
                                       TextColor="#6366F1" Opacity="0.6" VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                        <!-- Rec. Pedido → Slate -->
                        <Border Style="{DynamicResource PaymentLinkRow}"
                                BackgroundColor="#F8FAFC" Stroke="#CBD5E1">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="Auto, *, Auto" ColumnSpacing="10">
                                <Border Grid.Column="0" Style="{DynamicResource PaymentIconBadge}"
                                        BackgroundColor="#64748B">
                                    <Label Text="&#x1F4E5;" FontSize="16"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Border>
                                <Label Grid.Column="1" Text="Rec. Pedido"
                                       FontSize="13" FontAttributes="Bold"
                                       TextColor="#334155" VerticalOptions="Center"/>
                                <Label Grid.Column="2" Text="&#x276F;" FontSize="14"
                                       TextColor="#64748B" Opacity="0.6" VerticalOptions="Center"/>
                            </Grid>
                        </Border>

                    </VerticalStackLayout>

                </VerticalStackLayout>
            </ScrollView>
        </Border>

    </Grid>

</ContentPage>
